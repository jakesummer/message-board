<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Message Board</title>
  <link rel="stylesheet" href="style.css">
  <link rel="shortcut icon" href="/favicon.ico?v=2" type="image/x-icon">
  <script src="main.js" defer></script>
</head>
<body>
  <header>
    <h1>Message Board</h1>
    <p id="message-count">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M17,12V3A1,1 0 0,0 16,2H3A1,1 0 0,0 2,3V17L6,13H16A1,1 0 0,0 17,12M21,6H19V15H6V17A1,1 0 0,0 7,18H18L22,22V7A1,1 0 0,0 21,6Z" />
        </svg>
      <%= messages.length %> Messages
    </p>
    <button class="primary-btn" id="new-message-btn">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
        <path d="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" />
      </svg>
      <span>New Message</span>
    </button>
  </header>

  <main>
    <% for (let i = messages.length - 1; i >= 0; i--) { %>
      <%
        const message = messages[i];
        const names = message.user.trim().split(/\s+/).slice(0, 2);
        const initials = names.map((name) => name[0].toUpperCase()).join("");
      %>
      <div class="message-container">
        <div class="user-pfp"><%= initials %></div>
        <div class="right">
          <div class="user-name"><%= message.user %></div>
          <div class="message-date"><%= message.added %></div>
          <div class="message"><%= message.text %></div>
          <hr>
          <button class="hearts" data-id="<%= message.id %>">
            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24">
              <title>Heart</title>
              <path
                d="M12.1,18.55L12,18.65L11.89,18.55C7.14,14.24 4,11.39 4,8.5C4,6.5 5.5,5 7.5,5C9.04,5 10.54,6 11.07,7.36H12.93C13.46,6 14.96,5 16.5,5C18.5,5 20,6.5 20,8.5C20,11.39 16.86,14.24 12.1,18.55M16.5,3C14.76,3 13.09,3.81 12,5.08C10.91,3.81 9.24,3 7.5,3C4.42,3 2,5.41 2,8.5C2,12.27 5.4,15.36 10.55,20.03L12,21.35L13.45,20.03C18.6,15.36 22,12.27 22,8.5C22,5.41 19.58,3 16.5,3Z"
              />
            </svg>
            <span class="heart-count"><%= message.hearts %></span>
          </button>
        </div>
      </div>
    <% } %>
  </main>

  <dialog id="new-message-modal">
    <form method="POST" action="/" id="new-message-form">
      <fieldset>
        <legend>Add New Message</legend>

        <div class="label-input-group">
          <label for="user">Name</label>
          <input type="text" name="user" id="user" minlength="0" maxlength="16" placeholder="John Doe" required>
        </div>
        
        <div class="label-input-group">
          <label for="text">Message</label>
          <textarea name="text" id="text" minlength="0" maxlength="255" placeholder="What's on your mind?" required></textarea>
        </div>

        <div class="btn-container">
          <button type="button" id="close-modal-btn">Close</button>
          <button class="primary-btn" type="submit">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M3 20V4L22 12M5 17L16.85 12L5 7V10.5L11 12L5 13.5M5 17V7 13.5Z" />
            </svg>
            Post
          </button>
        </div>
      </fieldset>
    </form>
  </dialog>
</body>
</html>